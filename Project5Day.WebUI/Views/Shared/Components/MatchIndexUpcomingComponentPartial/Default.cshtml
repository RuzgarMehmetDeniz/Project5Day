@model List<Project5Day.WebUI.Dtos.MatchDtos.ResultMatchDto>

<div class="sec-ttl mcw-section" data-s="upcoming" style="margin-top:22px">🕐 &nbsp;Yaklaşan Maçlar</div>

@foreach (var item in Model)
{
    <div class="mc-wrap mcw" data-s="upcoming">
        <a href="#" class="mc">
            <div class="mc-time">
                <div class="mc-min bc">@item.MatchTime</div>
                @* Eğer tarih bugüne eşitse BUGÜN, değilse kısa tarih yazdırabilirsiniz *@
                <div class="sbadge sb-up">
                    @(item.MatchDate.Date == DateTime.Now.Date ? "BUGÜN" : item.MatchDate.ToString("dd.MM"))
                </div>
            </div>
            <div class="dvv"></div>
            <div class="mc-teams">
                <div class="mc-tr">
                    <div class="tl-sm">
                        <img src="@item.HomeTeamLogo" alt="logo" onerror="this.parentNode.textContent='@item.HomeTeamName.Substring(0, 3)'" />
                    </div>
                    <span class="tn">@item.HomeTeamName</span>
                    <span class="ts dim">—</span>
                </div>
                <div class="mc-tr">
                    <div class="tl-sm">
                        <img src="@item.AwayTeamLogo" alt="logo" onerror="this.parentNode.textContent='@item.AwayTeamName.Substring(0, 3)'" />
                    </div>
                    <span class="tn">@item.AwayTeamName</span>
                    <span class="ts dim">—</span>
                </div>
            </div>
            <a href="#" class="det-btn" onclick="return false"><i class="bi bi-calendar-check"></i> <span>Fikstür</span></a>
        </a>
    </div>
}