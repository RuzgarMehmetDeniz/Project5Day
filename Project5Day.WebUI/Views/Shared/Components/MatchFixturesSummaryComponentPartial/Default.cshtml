<div class="week-summary">
    <div class="ws-card">
        <div class="ws-num" style="color:var(--blue)">@ViewBag.TotalMatches</div>
        <div class="ws-lbl">Toplam Maç</div>
    </div>
    <div class="ws-card">
        <div class="ws-num" style="color:var(--gold)">@ViewBag.DerbyCount</div>
        <div class="ws-lbl">Zirve Derbisi</div>
    </div>
    <div class="ws-card">
        <div class="ws-num" style="color:var(--green)">@ViewBag.DayRange</div>
        <div class="ws-lbl">Maç Günleri</div>
    </div>
    <div class="ws-card">
        <div class="ws-num" style="color:var(--live)">@ViewBag.Day</div>
        <div class="ws-lbl">@ViewBag.MonthYear</div>
    </div>
</div>