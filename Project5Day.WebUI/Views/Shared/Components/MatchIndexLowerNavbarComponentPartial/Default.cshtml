@model List<ResultMatchWeekDto>
<section class="lg-head">
    @foreach (var item in Model)
    {
        <div class="wrap">
            <div class="row align-items-center">
                <div class="col-lg-7">
                    <div class="lg-badge"><i class="bi bi-trophy-fill"></i> @item.LeagueName</div>
                    <h1 class="lg-title">Hafta <span style="color:var(--green)">@item.WeekNumber</span> Sonuçları</h1>
                    <p class="lg-sub">@item.StartDate.ToString("dd MMMMMM") – @item.EndDate.ToString("dd MMMMMM")</p>
                </div>
                <div class="col-lg-5 d-none d-lg-block">
                    <div class="lg-stats">
                        <div style="text-align:center"><div class="ls-num">@ViewBag.LiveCount </div><div class="ls-lbl">Canlı</div></div>
                        <div style="text-align:center"><div class="ls-num">@ViewBag.FinishedCount </div><div class="ls-lbl">Biten</div></div>
                        <div style="text-align:center"><div class="ls-num">@ViewBag.UpcomingCount </div><div class="ls-lbl">Yaklaşan</div></div>
                    </div>
                </div>
            </div>
        </div>
    }
</section>