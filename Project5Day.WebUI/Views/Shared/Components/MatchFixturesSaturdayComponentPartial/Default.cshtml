<div class="day-group">
    <div class="day-header">
        <span class="day-title">Cumartesi</span>
        <span class="day-date">19 Nisan 2025</span>
        <div class="day-line"></div>
        <span class="day-badge db-tomorrow">5 Maç</span>
    </div>

    <!-- Liverpool vs Tottenham -->
    <div class="fx-card top-match">
        <div class="fx-top-badge"></div>
        <div class="fx-inner">
            <div class="fx-time-col">
                <div class="fx-time">12:30</div>
                <div class="fx-day-label">TV Maçı</div>
            </div>
            <div class="fx-divider"></div>
            <div class="fx-teams">
                <div class="fx-team-home">
                    <span class="fx-name home">Liverpool</span>
                    <div class="fx-logo">
                        <img src="https://upload.wikimedia.org/wikipedia/en/0/0c/Liverpool_FC.svg" alt="LIV" onerror="this.parentNode.textContent='LIV'" />
                    </div>
                </div>
                <div class="vs-block">
                    <span class="vs-text">VS</span>
                </div>
                <div class="fx-team-away">
                    <div class="fx-logo">
                        <img src="https://upload.wikimedia.org/wikipedia/en/b/b4/Tottenham_Hotspur.svg" alt="TOT" onerror="this.parentNode.textContent='TOT'" />
                    </div>
                    <span class="fx-name">Tottenham</span>
                </div>
            </div>
            <div class="fx-right">
                <span class="fx-stadium"><i class="bi bi-geo-alt" style="font-size:10px;margin-right:3px"></i>Anfield, Liverpool</span>
                <button class="notify-btn" onclick="toggleNotify(this)">
                    <i class="bi bi-bell"></i> <span>Bildir</span>
                </button>
            </div>
        </div>
        <div class="h2h-strip">
            <span class="h2h-label">Son 5 Karşılaşma</span>
            <div class="h2h-pills">
                <div class="h2h-p h2h-w">G</div>
                <div class="h2h-p h2h-w">G</div>
                <div class="h2h-p h2h-d">B</div>
                <div class="h2h-p h2h-w">G</div>
                <div class="h2h-p h2h-l">M</div>
            </div>
            <span class="h2h-avg">Ort. 3.2 gol / maç</span>
        </div>
        <div class="kp-strip">
            <span class="kp-label">İzlenecek Oyuncular</span>
            <span class="kp-tag"><i class="bi bi-lightning-fill"></i>Mohamed Salah</span>
            <span class="kp-tag"><i class="bi bi-lightning-fill"></i>Son Heung-min</span>
        </div>
    </div>

