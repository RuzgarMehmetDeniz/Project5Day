@model List<ResultMatchDto>

<div class="sec-ttl mcw-section" data-s="live">🔴 &nbsp;Canlı Maçlar</div>
@foreach (var item in Model)
{
    // FinalScore artık C# tarafında FirstHalf veya SecondHalf olarak belirlendi
    var scoreParts = !string.IsNullOrEmpty(item.FinalScore) ? item.FinalScore.Split('-') : new string[] { "0", "0" };
    var hScore = scoreParts[0];
    var aScore = scoreParts.Length > 1 ? scoreParts[1] : "0";

    <div class="mc-wrap mcw" data-s="live">
        <div class="mc live lp">
            <div class="mc-time">
                <div class="mc-min lc">@item.MatchTime</div>
                <div class="sbadge sb-live"><span class="live-dot"></span>CANLI</div>
            </div>
            <div class="dvv"></div>
            <div class="mc-teams">
                <div class="mc-tr">
                    <div class="tl-sm"><img src="@item.HomeTeamLogo" alt="Logo" /></div>
                    <span class="tn">@item.HomeTeamName</span>
                    <span class="ts">@hScore</span>
                </div>
                <div class="mc-tr">
                    <div class="tl-sm"><img src="@item.AwayTeamLogo" alt="Logo" /></div>
                    <span class="tn">@item.AwayTeamName</span>
                    <span class="ts">@aScore</span>
                </div>
            </div>
            <a href="#" class="det-btn" onclick="return false"><i class="bi bi-chevron-right"></i> <span>Detay</span></a>
        </div>
    </div>
}