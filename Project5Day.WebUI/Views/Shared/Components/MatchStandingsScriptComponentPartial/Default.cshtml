@model dynamic

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // ── DATA ──
    // C# Controller/ViewComponent tarafından gönderilen dinamik listeyi alıyoruz
    const rawData = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model));

    // Veriyi senin JS motorunun anlayacağı yapıya mapliyoruz
    const teams = rawData.map((t, index) => {
        let zone = 'none';
        let pos = index + 1;

        // Grup Mantığı Hesaplaması
        if (pos <= 4) zone = 'champ';      // İlk 4: Şampiyonlar Ligi
        else if (pos <= 6) zone = 'uel';   // 5 ve 6: Avrupa Ligi
        else if (pos >= 18) zone = 'rel';  // Son 3: Küme Düşme

        return {
            pos: pos,
            name: t.name,
            short: t.shortName,
            logo: t.logo,
            mp: t.mp,
            w: t.w,
            d: t.d,
            l: t.l,
            gf: t.gf,
            ga: t.ga,
            pts: t.pts,
            zone: zone
        };
    });

    const zoneColors = {
        champ: 'cl-champ', uel: 'cl-uel', rel: 'cl-rel', none: 'cl-none'
    };

    const posColors = {
        champ: 'top1', uel: 'euro', rel: 'rel', none: ''
    };

    function renderTable() {
        const tbody = document.getElementById('tableBody');
        if(!tbody) return;

        let html = '';

        teams.forEach((t, i) => {
            const gd = t.gf - t.ga;
            const gdStr = gd > 0 ? '+' + gd : gd;
            const gdClass = gd > 0 ? 'pos' : gd < 0 ? 'neg' : 'zero';
            const posClass = posColors[t.zone] || '';
            const zClass = zoneColors[t.zone] || 'cl-none';
            const isPtsTop = t.zone === 'champ';

            // Dinamik Grup Başlıkları
            let sectionLabel = '';
            if (i === 0) sectionLabel = `<tr><td colspan="11"><div class="zone-lbl">🏆 &nbsp;Şampiyonlar Ligi Grupları (1–4)</div></td></tr>`;
            if (i === 4) sectionLabel = `<tr><td colspan="11"><div class="zone-lbl">🔵 &nbsp;UEFA Avrupa Ligi (5–6)</div></td></tr>`;
            if (i === 6) sectionLabel = `<tr><td colspan="11"><div class="zone-lbl">— &nbsp;Lig Sıralaması (7–17)</div></td></tr>`;
            if (i === 17) sectionLabel = `<tr><td colspan="11"><div class="zone-lbl">🔴 &nbsp;Küme Düşme Hattı (18–20)</div></td></tr>`;

            html += sectionLabel;
            html += `
            <tr class="std-row" title="${t.name}">
                <td style="padding:0;width:4px">
                    <div class="pos-strip ${zClass}" style="height:44px;border-radius:var(--r1) 0 0 var(--r1)"></div>
                </td>
                <td><span class="pos-num ${posClass}">${t.pos}</span></td>
                <td>
                    <div class="team-cell">
                        <div class="t-logo">
                            <img src="${t.logo}" alt="${t.short}" onerror="this.parentNode.textContent='${t.short}'"/>
                        </div>
                        <div class="t-name">
                            <span class="t-full">${t.name}</span>
                            <span class="t-short">${t.short}</span>
                        </div>
                    </div>
                </td>
                <td class="s-mp">${t.mp}</td>
                <td class="s-w">${t.w}</td>
                <td class="s-d">${t.d}</td>
                <td class="s-l">${t.l}</td>
                <td class="s-gf hide-sm">${t.gf}</td>
                <td class="s-ga hide-sm">${t.ga}</td>
                <td class="s-gd ${gdClass}">${gdStr}</td>
                <td class="s-pts ${isPtsTop ? 'pts-top' : ''}">${t.pts}</td>
            </tr>`;
        });

        tbody.innerHTML = html;
    }

    // Mobil Menü ve Scroll Efektleri
    const tog = document.getElementById('tog');
    if(tog) {
        tog.addEventListener('click', () => {
            const mob = document.getElementById('mobMenu');
            mob.classList.toggle('open');
            tog.innerHTML = mob.classList.contains('open') ? '<i class="bi bi-x-lg"></i>' : '<i class="bi bi-list"></i>';
        });
    }

    window.addEventListener('scroll', () => {
        const nb = document.querySelector('.nb');
        if(nb) nb.style.boxShadow = window.scrollY > 8 ? '0 4px 32px rgba(0,0,0,.7)' : '0 2px 24px rgba(0,0,0,.5)';
    });

    // Satır Animasyonu
    function animateRows() {
        const rows = document.querySelectorAll('.std-row');
        rows.forEach((r, i) => {
            r.style.opacity = '0';
            r.style.transform = 'translateY(10px)';
            setTimeout(() => {
                r.style.transition = 'opacity .3s ease, transform .3s ease';
                r.style.opacity = '1';
                r.style.transform = 'translateY(0)';
            }, 30 + i * 28);
        });
    }

    // Başlat
    renderTable();
    animateRows();
</script>