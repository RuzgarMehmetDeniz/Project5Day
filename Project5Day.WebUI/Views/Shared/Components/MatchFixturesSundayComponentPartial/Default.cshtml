@model List<Project5Day.WebUI.Dtos.MatchDtos.ResultMatchDto>

<div class="day-group">
    @if (Model.Any())
    {
        <div class="day-header">
            <span class="day-title">@Model.First().MatchDate.ToString("dddd")</span>
            <span class="day-date">@Model.First().MatchDate.ToString("dd MMMM yyyy")</span>
            <div class="day-line"></div>
            <span class="day-badge db-sun">Hafta Kapanışı</span>
        </div>

        @foreach (var item in Model)
        {
            @* Pazartesi gününün ilk maçını Zirve Derbisi tasarımıyla gösteriyoruz *@
            bool isTopMatch = (item == Model.First());

            <div class="fx-card @(isTopMatch ? "top-match" : "")">
                @if (isTopMatch)
                {
                    @* Sarı rozet ve efektleri getiren kısım *@
                    <div class="fx-top-badge"></div>
                }

                <div class="fx-inner">
                    <div class="fx-time-col">
                        <div class="fx-time">@item.MatchTime</div>

                        @if (isTopMatch)
                        {
                            @* Maç saatinin altındaki sarı TOP etiketi *@
                            <div class="top-match-tag">★ TOP</div>
                        }
                        else
                        {
                            <div class="fx-day-label">Pazartesi</div>
                        }
                    </div>

                    <div class="fx-divider"></div>

                    <div class="fx-teams">
                        <div class="fx-team-home">
                            <span class="fx-name home">@item.HomeTeamName</span>
                            <div class="fx-logo">
                                <img src="@item.HomeTeamLogo" alt="home" onerror="this.parentNode.textContent='@item.HomeTeamName.Substring(0, 3)'" />
                            </div>
                        </div>
                        <div class="vs-block">
                            <span class="vs-text">VS</span>
                        </div>
                        <div class="fx-team-away">
                            <div class="fx-logo">
                                <img src="@item.AwayTeamLogo" alt="away" onerror="this.parentNode.textContent='@item.AwayTeamName.Substring(0, 3)'" />
                            </div>
                            <span class="fx-name">@item.AwayTeamName</span>
                        </div>
                    </div>

                    <div class="fx-right">
                        <span class="fx-stadium">
                            <i class="bi bi-geo-alt" style="font-size:10px;margin-right:3px"></i>@item.StadiumName
                        </span>
                        <button class="notify-btn" onclick="toggleNotify(this)">
                            <i class="bi bi-bell"></i> <span>Bildir</span>
                        </button>
                    </div>
                </div>
            </div>
        }
    }
</div>