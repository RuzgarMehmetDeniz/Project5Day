<div class="grid-2">
    <div class="card">
        <div class="card-header">
            <div>
                <div class="card-title">Puan Durumu</div>
                <div class="card-subtitle">2024/25 Sezonu</div>
            </div>
            <button class="btn btn-outline btn-sm">Tümü</button>
        </div>
        <div class="card-body" style="padding: 0 0 4px;">
            <table class="standings-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Takım</th>
                        <th class="center">O</th>
                        <th class="center">G</th>
                        <th class="center">B</th>
                        <th class="center">M</th>
                        <th class="center">Puan</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int rank = 1;
                    }
                    @foreach (var item in ViewBag.Standings)
                    {
                        <tr>
                            <td><span class="team-rank @(rank <= 2 ? "top" : "")">@rank</span></td>
                            <td>
                                <div class="table-cell-flex">
                                    <div class="table-avatar" style="background:#e8f5ed;color:#065f2a">
                                        @item.Team.Name.Substring(0, 2).ToUpper()
                                    </div>
                                    @item.Team.Name
                                </div>
                            </td>
                            <td class="center">@item.O</td>
                            <td class="center">@item.G</td>
                            <td class="center">@item.B</td>
                            <td class="center">@item.M</td>
                            <td class="center"><span class="pts-badge">@item.Puan</span></td>
                        </tr>
                        rank++;
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <div class="card-title">En Çok Gol Atanlar</div>
            <span class="card-badge">Top 5</span>
        </div>
        <div class="card-body" style="padding-top: 8px;">
            @{
                int sRank = 1;
            }
            @foreach (var scorer in ViewBag.TopScorers)
            {
                <div class="scorer-item">
                    <div class="scorer-rank @(sRank <= 1 ? "gold" : "")">@sRank</div>
                    <div class="scorer-avatar" style="background:#f0ecfd;color:#5b21b6">
                        @scorer.PlayerName.Substring(0, 2).ToUpper()
                    </div>
                    <div class="scorer-info">
                        <div class="scorer-name">@scorer.PlayerName</div>
                        <div class="scorer-team">@scorer.TeamName</div>
                    </div>
                    <div class="scorer-goals">@scorer.GoalCount</div>
                </div>
                sRank++;
            }
        </div>
    </div>
</div>