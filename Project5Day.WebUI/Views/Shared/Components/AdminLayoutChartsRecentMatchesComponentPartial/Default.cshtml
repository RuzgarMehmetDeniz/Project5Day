<div class="grid-3-1">
    <!-- Chart -->
    <div class="card">
        <div class="card-header">
            <div>
                <div class="card-title">Haftalık Gol İstatistikleri</div>
                <div class="card-subtitle">Son 8 hafta</div>
            </div>
            <div class="card-badge">Sezon 2024/25</div>
        </div>
        <div class="card-body">
            <div class="chart-container">
                <canvas id="goalChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Recent Matches -->
    <div class="card">
        <div class="card-header">
            <div class="card-title">Son Maçlar</div>
            <button class="btn btn-outline btn-sm" onclick="showPage('fixtures')">Tümü</button>
        </div>
        <div class="card-body" style="padding-top:8px;">
            <div class="match-item">
                <div class="team-badge" style="background:#e8f5ed;color:#065f2a">GS</div>
                <div class="match-teams">Galatasaray <span style="color:var(--text-muted);font-weight:400">vs</span> Beşiktaş</div>
                <div class="match-score">3 – 1</div>
                <div class="match-meta">
                    <div class="date">15 Nis</div>
                    <span class="match-status status-done">Bitti</span>
                </div>
            </div>
            <div class="match-item">
                <div class="team-badge" style="background:#fef2f2;color:#991b1b">FB</div>
                <div class="match-teams">Fenerbahçe <span style="color:var(--text-muted);font-weight:400">vs</span> Trabzon</div>
                <div class="match-score" style="color:var(--danger);border-color:#ffd0d0">2 – 2</div>
                <div class="match-meta">
                    <div class="date">14 Nis</div>
                    <span class="match-status status-done">Bitti</span>
                </div>
            </div>
            <div class="match-item">
                <div class="team-badge" style="background:#eff6ff;color:#1e40af">BJK</div>
                <div class="match-teams">Beşiktaş <span style="color:var(--text-muted);font-weight:400">vs</span> Antalya</div>
                <div class="match-score">— – —</div>
                <div class="match-meta">
                    <div class="date">18 Nis</div>
                    <span class="match-status status-upcoming">Yakında</span>
                </div>
            </div>
        </div>
    </div>
</div>
