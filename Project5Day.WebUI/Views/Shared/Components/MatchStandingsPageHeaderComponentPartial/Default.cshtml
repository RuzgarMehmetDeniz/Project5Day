@model Project5Day.WebApi.Entities.MatchWeek

<section class="pg-head">
    <div class="wrap">
        <div class="row align-items-center">
            <div class="col-lg-8">
                @* İkon ve Lig İsmi Statik Olarak Ayarlandı *@
                <div class="pg-badge"><i class="bi bi-trophy-fill"></i>@Model.LeagueName</div>

                <h1 class="pg-title">Puan <span style="color:var(--green)">Durumu</span></h1>

                <p class="pg-sub">
                    2025 / 2026 Sezonu &nbsp;·&nbsp;
                    @if (Model != null)
                    {
                        @* Sadece Hafta Bilgisi Dinamik *@
                        <span>@Model.WeekNumber. Hafta Sonrası</span>
                    }
                    else
                    {
                        @* Veri yoksa varsayılan bir değer gösterilebilir *@
                        <span>36. Hafta Sonrası</span>
                    }
                </p>
            </div>
            <div class="col-lg-4 mt-3 mt-lg-0">
                <div class="legend">
                    <div class="leg-item"><div class="leg-dot" style="background:rgba(255,214,0,.8)"></div>Şampiyon</div>
                    <div class="leg-item"><div class="leg-dot" style="background:var(--green)"></div>Şampiyonlar Ligi</div>
                    <div class="leg-item"><div class="leg-dot" style="background:var(--blue)"></div>UEFA Ligi</div>
                    <div class="leg-item"><div class="leg-dot" style="background:var(--live)"></div>Küme Düşme</div>
                </div>
            </div>
        </div>
    </div>
</section>