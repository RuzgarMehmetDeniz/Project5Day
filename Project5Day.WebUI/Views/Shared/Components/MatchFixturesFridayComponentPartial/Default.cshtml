<div class="day-group">
    <div class="day-header">
        <span class="day-title">Cuma</span>
        <span class="day-date">18 Nisan 2025</span>
        <div class="day-line"></div>
        <span class="day-badge db-today">Bu Hafta Açılışı</span>
    </div>

    <!-- Man City vs Chelsea — TOP MATCH -->
    <div class="fx-card top-match">
        <div class="fx-top-badge"></div>
        <div class="fx-inner">
            <div class="fx-time-col">
                <div class="fx-time">20:00</div>
                <div class="top-match-tag">★ TOP</div>
            </div>
            <div class="fx-divider"></div>
            <div class="fx-teams">
                <div class="fx-team-home">
                    <span class="fx-name home">Manchester City</span>
                    <div class="fx-logo">
                        <img src="https://upload.wikimedia.org/wikipedia/en/e/eb/Manchester_City_FC_badge.svg" alt="MCI" onerror="this.parentNode.textContent='MCI'" />
                    </div>
                </div>
                <div class="vs-block">
                    <span class="vs-text">VS</span>
                </div>
                <div class="fx-team-away">
                    <div class="fx-logo">
                        <img src="https://upload.wikimedia.org/wikipedia/en/c/cc/Chelsea_FC.svg" alt="CHE" onerror="this.parentNode.textContent='CHE'" />
                    </div>
                    <span class="fx-name">Chelsea</span>
                </div>
            </div>
            <div class="fx-right">
                <span class="fx-stadium"><i class="bi bi-geo-alt" style="font-size:10px;margin-right:3px"></i>Etihad Stadium</span>
                <button class="notify-btn" onclick="toggleNotify(this)">
                    <i class="bi bi-bell"></i> <span>Bildir</span>
                </button>
            </div>
        </div>
        <div class="h2h-strip">
            <span class="h2h-label">Son 5 Karşılaşma</span>
            <div class="h2h-pills">
                <div class="h2h-p h2h-w">G</div>
                <div class="h2h-p h2h-l">M</div>
                <div class="h2h-p h2h-w">G</div>
                <div class="h2h-p h2h-d">B</div>
                <div class="h2h-p h2h-w">G</div>
            </div>
            <span class="h2h-avg">Ort. 2.8 gol / maç</span>
        </div>
        <div class="kp-strip">
            <span class="kp-label">İzlenecek Oyuncular</span>
            <span class="kp-tag"><i class="bi bi-lightning-fill"></i>Erling Haaland</span>
            <span class="kp-tag"><i class="bi bi-lightning-fill"></i>Cole Palmer</span>
            <span class="kp-tag"><i class="bi bi-lightning-fill"></i>Phil Foden</span>
        </div>
    </div>

</div>
