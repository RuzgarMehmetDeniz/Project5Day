@using Project5Day.WebApi.Entities
@model Project5Day.WebApi.Entities.Match

@if (Model == null)
{
    <p class="text-muted text-center py-5">Maç bulunamadı.</p>
    return;
}

@{
    var allEvents = Model.MatchEvents?.OrderBy(e => e.Minute).ToList() ?? new List<MatchEvent>();

    var goals = allEvents.Where(e => e.Type == EventType.Goal).ToList();
    var homeGoals = goals.Where(e => e.IsHomeTeam).ToList();
    var awayGoals = goals.Where(e => !e.IsHomeTeam).ToList();

    var cards = allEvents.Where(e => e.Type == EventType.YellowCard || e.Type == EventType.RedCard).ToList();
    var homeCards = cards.Where(e => e.IsHomeTeam).ToList();
    var awayCards = cards.Where(e => !e.IsHomeTeam).ToList();

    var subs = allEvents.Where(e => e.Type == EventType.Substitution).ToList();
    var homeSubs = subs.Where(e => e.IsHomeTeam).ToList();
    var awaySubs = subs.Where(e => !e.IsHomeTeam).ToList();

    var stat = Model.MatchStatistic;

    int homeYellow = homeCards.Count(e => e.Type == EventType.YellowCard);
    int homeRed = homeCards.Count(e => e.Type == EventType.RedCard);
    int awayYellow = awayCards.Count(e => e.Type == EventType.YellowCard);
    int awayRed = awayCards.Count(e => e.Type == EventType.RedCard);

    int SafePct(int val, int total) => total == 0 ? 50 : (int)Math.Round(val * 100.0 / total);
}

<div class="row g-4 mt-1">

    <!-- ===================== SOL KOLON ===================== -->
    <div class="col-lg-7">

        <!-- MAÇ OLAYLARI -->
        <div class="dc">
            <div class="dc-title">
                <i class="bi bi-activity me-2" style="color:var(--green)"></i>Maç Olayları
            </div>
            <div class="tl-wrap">
                <div class="tl-line"></div>

                @foreach (var ev in allEvents)
                {
                    bool isHome = ev.IsHomeTeam;

                    string chipClass = ev.Type == EventType.Goal ? "goal-ev"
                    : ev.Type == EventType.YellowCard ? "yel-ev"
                    : ev.Type == EventType.RedCard ? "red-ev"
                    : "sub-ev";

                    string icoClass = ev.Type == EventType.Goal ? "ei-goal"
                    : ev.Type == EventType.YellowCard ? "ei-yel"
                    : ev.Type == EventType.RedCard ? "ei-red"
                    : "ei-sub";

                    string icoHtml = ev.Type == EventType.Goal
                    ? "<i class='bi bi-circle-fill' style='font-size:9px'></i>"
                    : ev.Type == EventType.Substitution
                    ? "<i class='bi bi-arrow-left-right'></i>"
                    : "<i class='bi bi-square-fill' style='font-size:10px'></i>";

                    string detail = ev.Type == EventType.Substitution
                    ? $"↑ {ev.PlayerIn} / ↓ {ev.PlayerOut}"
                    : ev.EventDetail ?? "";

                    <div class="tl-ev">
                        <div class="tl-home">
                            @if (isHome)
                            {
                                <div class="chip home @chipClass">
                                    <div class="ev-ico @icoClass">@Html.Raw(icoHtml)</div>
                                    <div>
                                        <div class="ev-pl">@ev.PlayerName</div>
                                        @if (!string.IsNullOrWhiteSpace(detail))
                                        {
                                            <div class="ev-dt">@detail</div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="tl-min-c">
                            <div class="min-b">@ev.Minute'</div>
                        </div>
                        <div class="tl-away">
                            @if (!isHome)
                            {
                                <div class="chip away @chipClass">
                                    <div class="ev-ico @icoClass">@Html.Raw(icoHtml)</div>
                                    <div>
                                        <div class="ev-pl">@ev.PlayerName</div>
                                        @if (!string.IsNullOrWhiteSpace(detail))
                                        {
                                            <div class="ev-dt">@detail</div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

            </div>
        </div>

        <!-- GOLLER -->
        <div class="dc">
            <div class="dc-title">
                <i class="bi bi-circle-fill me-2" style="color:var(--green);font-size:9px"></i>Goller
            </div>
            <div class="split2">
                <div class="box2">
                    <div class="box2-title">⚽ @Model.HomeTeam?.Name</div>
                    @foreach (var g in homeGoals)
                    {
                        <div class="gl">
                            <div class="gl-ico">⚽</div>
                            <div class="gl-pl">@g.PlayerName</div>
                            <div class="gl-min">@g.Minute'</div>
                        </div>
                    }
                    @if (!homeGoals.Any())
                    {
                        <span class="no-ev">-</span>
                    }
                </div>
                <div class="box2">
                    <div class="box2-title">⚽ @Model.AwayTeam?.Name</div>
                    @foreach (var g in awayGoals)
                    {
                        <div class="gl">
                            <div class="gl-ico">⚽</div>
                            <div class="gl-pl">@g.PlayerName</div>
                            <div class="gl-min">@g.Minute'</div>
                        </div>
                    }
                    @if (!awayGoals.Any())
                    {
                        <span class="no-ev">-</span>
                    }
                </div>
            </div>
        </div>

        <!-- KARTLAR -->
        <div class="dc">
            <div class="dc-title">
                <i class="bi bi-square-fill me-2" style="color:var(--yellow);font-size:10px"></i>Kartlar
            </div>
            <div class="split2">
                <div class="box2">
                    <div class="box2-title">@Model.HomeTeam?.Name</div>
                    @foreach (var c in homeCards)
                    {
                        <div class="gl">
                            <div class="@(c.Type == EventType.YellowCard ? "ycard" : "rcard")"></div>
                            <div class="gl-pl">@c.PlayerName</div>
                            <div class="gl-min">@c.Minute'</div>
                        </div>
                    }
                    @if (!homeCards.Any())
                    {
                        <span class="no-ev">-</span>
                    }
                </div>
                <div class="box2">
                    <div class="box2-title">@Model.AwayTeam?.Name</div>
                    @foreach (var c in awayCards)
                    {
                        <div class="gl">
                            <div class="@(c.Type == EventType.YellowCard ? "ycard" : "rcard")"></div>
                            <div class="gl-pl">@c.PlayerName</div>
                            <div class="gl-min">@c.Minute'</div>
                        </div>
                    }
                    @if (!awayCards.Any())
                    {
                        <span class="no-ev">-</span>
                    }
                </div>
            </div>
        </div>

        <!-- OYUNCU DEĞİŞİKLİKLERİ -->
        <div class="dc">
            <div class="dc-title">
                <i class="bi bi-arrow-left-right me-2" style="color:var(--blue)"></i>Oyuncu Değişiklikleri
            </div>

            @if (homeSubs.Any())
            {
                <div class="sub-lbl">@Model.HomeTeam?.Name</div>
                @foreach (var s in homeSubs)
                {
                    <div class="sub-r">
                        <div class="sub-min">@s.Minute'</div>
                        <div class="sub-in">↑ @s.PlayerIn</div>
                        <div class="sub-arr">⇄</div>
                        <div class="sub-out">↓ @s.PlayerOut</div>
                    </div>
                }
            }

            @if (awaySubs.Any())
            {
                <div class="sub-lbl mt-2">@Model.AwayTeam?.Name</div>
                @foreach (var s in awaySubs)
                {
                    <div class="sub-r">
                        <div class="sub-min">@s.Minute'</div>
                        <div class="sub-in">↑ @s.PlayerIn</div>
                        <div class="sub-arr">⇄</div>
                        <div class="sub-out">↓ @s.PlayerOut</div>
                    </div>
                }
            }

            @if (!homeSubs.Any() && !awaySubs.Any())
            {
                <span class="no-ev">Değişiklik yapılmadı.</span>
            }
        </div>

    </div>

    <!-- ===================== SAĞ KOLON ===================== -->
    <div class="col-lg-5">

        <!-- MAÇ ÖZETİ -->
        <div class="dc">
            <div class="dc-title">
                <i class="bi bi-bar-chart-fill me-2" style="color:var(--blue)"></i>Maç Özeti
            </div>
            <div class="sc-pills">
                <div class="sc-pill">
                    <div class="sp-lbl">İlk Yarı</div>
                    <div class="sp-val">@Model.FirstHalfScore</div>
                </div>
                <div class="sc-pill">
                    <div class="sp-lbl">İkinci Yarı</div>
                    <div class="sp-val">@Model.SecondHalfScore</div>
                </div>
                <div class="sc-pill">
                    <div class="sp-lbl">Sonuç</div>
                    <div class="sp-val" style="color:var(--green)">@Model.FinalScore</div>
                </div>
            </div>
        </div>

        <!-- İSTATİSTİKLER -->
        @if (stat != null)
        {
            int posTotal = stat.HomePossession + stat.AwayPossession;
            int shotTotal = stat.HomeShots + stat.AwayShots;
            int sotTotal = stat.HomeShotsOnTarget + stat.AwayShotsOnTarget;
            int passTotal = stat.HomePasses + stat.AwayPasses;
            int paTotal = stat.HomePassAccuracy + stat.AwayPassAccuracy;
            int cornTotal = stat.HomeCorners + stat.AwayCorners;
            int foulTotal = stat.HomeFouls + stat.AwayFouls;
            int offTotal = stat.HomeOffsides + stat.AwayOffsides;

            <div class="dc">
                <div class="dc-title">
                    <i class="bi bi-graph-up me-2" style="color:var(--green)"></i>İstatistikler
                </div>

                @{
                    var statList = new[]
                    {
                        (Label: "Topa Sahip Olma", HV: stat.HomePossession + "%", AV: stat.AwayPossession + "%", HP: SafePct(stat.HomePossession, posTotal)),
                        (Label: "Şut",             HV: stat.HomeShots.ToString(),          AV: stat.AwayShots.ToString(),          HP: SafePct(stat.HomeShots, shotTotal)),
                        (Label: "İsabetli Şut",    HV: stat.HomeShotsOnTarget.ToString(),  AV: stat.AwayShotsOnTarget.ToString(),  HP: SafePct(stat.HomeShotsOnTarget, sotTotal)),
                        (Label: "Pas",             HV: stat.HomePasses.ToString(),         AV: stat.AwayPasses.ToString(),         HP: SafePct(stat.HomePasses, passTotal)),
                        (Label: "Pas İsabeti",     HV: stat.HomePassAccuracy + "%",        AV: stat.AwayPassAccuracy + "%",        HP: SafePct(stat.HomePassAccuracy, paTotal)),
                        (Label: "Korner",          HV: stat.HomeCorners.ToString(),        AV: stat.AwayCorners.ToString(),        HP: SafePct(stat.HomeCorners, cornTotal)),
                        (Label: "Faul",            HV: stat.HomeFouls.ToString(),          AV: stat.AwayFouls.ToString(),          HP: SafePct(stat.HomeFouls, foulTotal)),
                        (Label: "Ofsayt",          HV: stat.HomeOffsides.ToString(),       AV: stat.AwayOffsides.ToString(),       HP: SafePct(stat.HomeOffsides, offTotal)),
                        };
                }

                @foreach (var s in statList)
                {
                    <div class="stat-r">
                        <div class="sv-h">@s.HV</div>
                        <div class="sl">@s.Label</div>
                        <div class="sv-a">@s.AV</div>
                    </div>
                    <div class="bar-r">
                        <div class="bh"><div class="f" style="width:@(s.HP)%"></div></div>
                        <div></div>
                        <div class="ba"><div class="f" style="width:@(100 - s.HP)%"></div></div>
                    </div>
                }

                <div class="stat-r" style="margin-bottom:0">
                    <div class="sv-h" style="color:var(--yellow)">@homeYellow</div>
                    <div class="sl">Sarı Kart</div>
                    <div class="sv-a" style="color:var(--yellow)">@awayYellow</div>
                </div>
                <div class="stat-r" style="margin-top:8px;margin-bottom:0">
                    <div class="sv-h" style="color:var(--red)">@homeRed</div>
                    <div class="sl">Kırmızı Kart</div>
                    <div class="sv-a" style="color:@(awayRed > 0 ? "var(--red)" : "var(--t3)")">@awayRed</div>
                </div>

                <div style="display:flex;justify-content:space-between;margin-top:18px;padding-top:14px;border-top:1px solid var(--border)">
                    <div style="display:flex;align-items:center;gap:7px">
                        <div style="width:9px;height:9px;border-radius:50%;background:var(--blue)"></div>
                        <span style="font-size:12px;font-weight:700;color:var(--t2)">@Model.HomeTeam?.Name</span>
                    </div>
                    <div style="display:flex;align-items:center;gap:7px">
                        <span style="font-size:12px;font-weight:700;color:var(--t2)">@Model.AwayTeam?.Name</span>
                        <div style="width:9px;height:9px;border-radius:50%;background:var(--live)"></div>
                    </div>
                </div>
            </div>
        }

        <!-- MAÇ BİLGİLERİ -->
        <div class="dc">
            <div class="dc-title">
                <i class="bi bi-info-circle me-2" style="color:var(--t3)"></i>Maç Bilgileri
            </div>
            <div class="mi-row"><span class="mi-key">Lig</span><span class="mi-val" style="color:var(--gold)">Premier League</span></div>
            <div class="mi-row"><span class="mi-key">Sezon</span><span class="mi-val">2024 / 2025</span></div>
            <div class="mi-row"><span class="mi-key">Hafta</span><span class="mi-val">Hafta @Model.WeekNumber</span></div>
            <div class="mi-row"><span class="mi-key">Stadyum</span><span class="mi-val">@Model.Stadium?.Name</span></div>
            <div class="mi-row"><span class="mi-key">Şehir</span><span class="mi-val">@Model.Stadium?.City</span></div>
            <div class="mi-row"><span class="mi-key">Seyirci</span><span class="mi-val">@Model.SpectatorCount.ToString("N0")</span></div>
            <div class="mi-row"><span class="mi-key">Hakem</span><span class="mi-val">@Model.RefereeName</span></div>
            <div class="mi-row"><span class="mi-key">Tarih</span><span class="mi-val">@Model.MatchDate.ToString("dd MMMM yyyy")</span></div>
            <div class="mi-row"><span class="mi-key">Saat</span><span class="mi-val">@Model.MatchTime</span></div>
        </div>

    </div>
</div>
