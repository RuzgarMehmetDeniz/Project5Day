@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
    @await Component.InvokeAsync("AdminLayoutHeadComponentPartial")
<body>

    <!-- Sidebar Overlay -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <!-- SIDEBAR -->
    @await Component.InvokeAsync("AdminLayoutSidebarComponentPartial")


    <!-- MAIN -->
    <div class="main">
        <!-- HEADER -->
        @await Component.InvokeAsync("AdminLayoutHeaderComponentPartial")

        <!-- CONTENT -->
        <div class="content">

            <!-- ===== DASHBOARD PAGE ===== -->
            <div class="page active" id="page-dashboard">
                @await Component.InvokeAsync("AdminLayoutDashboardPageHeaderComponentPartial")

                <!-- Stat Cards -->
                @await Component.InvokeAsync("AdminLayoutDashboardStatCardsComponentPartial")

                <!-- Charts + Recent Matches -->
                @await Component.InvokeAsync("AdminLayoutDashboardChartsRecentMatchesComponentPartial")

                <!-- Standings + Top Scorers -->
                @await Component.InvokeAsync("AdminLayoutDashboardStandingsTopScorersComponentPartial")

            </div>
        </div>
    </div>

    <script>
        // 1. Sayfa Navigasyonu (Sekme Değiştirme)
        function showPage(pageId) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));

            const targetPage = document.getElementById('page-' + pageId);
            if (targetPage) {
                targetPage.classList.add('active');
            }

            const labels = {
                dashboard: 'Dashboard',
                teams: 'Takım Yönetimi',
                players: 'Oyuncu Yönetimi',
                fixtures: 'Maç Yönetimi',
                standings: 'Puan Durumu',
                stats: 'İstatistikler'
            };

            const breadcrumb = document.getElementById('breadcrumb');
            if (breadcrumb) {
                breadcrumb.textContent = labels[pageId] || pageId;
            }

            // Aktif menü öğesini işaretle
            document.querySelectorAll('.nav-item').forEach(n => {
                if (n.getAttribute('onclick') && n.getAttribute('onclick').includes("'" + pageId + "'")) {
                    n.classList.add('active');
                }
            });

            if (window.innerWidth < 769) closeSidebar();
        }

        // 2. Sidebar (Yan Menü) Kontrolleri
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('open');
            document.getElementById('sidebarOverlay').classList.toggle('open');
        }

        function closeSidebar() {
            document.getElementById('sidebar').classList.remove('open');
            document.getElementById('sidebarOverlay').classList.remove('open');
        }

        // 3. Modal (Açılır Pencere) İşlemleri
        function openModal(id) {
            const modal = document.getElementById(id);
            if (modal) modal.classList.add('open');
        }

        function closeModal(id) {
            const modal = document.getElementById(id);
            if (modal) modal.classList.remove('open');
        }

        // Dışarı tıklandığında modal kapatma
        document.querySelectorAll('.modal-overlay').forEach(o => {
            o.addEventListener('click', e => {
                if (e.target === o) o.classList.remove('open');
            });
        });

        // 4. Global Grafik Tasarım Değişkenleri (Partial'lar bunları kullanacak)
        const pitchGreen = '#1a7a3f';
        const pitchLight = '#22a050';
        const accentYellow = '#c8f135';
        const dangerRed = '#e04040';
        const infoBlue = '#2080c0';
        const amberOrange = '#d97706';
        const gridColor = 'rgba(0,0,0,0.06)';
        const fontFamily = "'DM Sans', sans-serif";
        const defaultFont = { family: fontFamily, size: 12 };
    </script>

</body>
</html>