    <script>
        // Navigation
        function showPage(pageId) {
          document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
          document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
          document.getElementById('page-' + pageId).classList.add('active');
          const labels = { dashboard:'Dashboard', teams:'Takım Yönetimi', players:'Oyuncu Yönetimi', fixtures:'Maç Yönetimi', standings:'Puan Durumu', stats:'İstatistikler' };
          document.getElementById('breadcrumb').textContent = labels[pageId] || pageId;
          event.currentTarget && event.currentTarget.classList.add('active');
          // Set active nav
          document.querySelectorAll('.nav-item').forEach(n => {
            if (n.getAttribute('onclick') && n.getAttribute('onclick').includes("'" + pageId + "'")) n.classList.add('active');
          });
          if (window.innerWidth < 769) closeSidebar();
        }

        // Sidebar
        function toggleSidebar() {
          document.getElementById('sidebar').classList.toggle('open');
          document.getElementById('sidebarOverlay').classList.toggle('open');
        }
        function closeSidebar() {
          document.getElementById('sidebar').classList.remove('open');
          document.getElementById('sidebarOverlay').classList.remove('open');
        }

        // Modals
        function openModal(id) { document.getElementById(id).classList.add('open'); }
        function closeModal(id) { document.getElementById(id).classList.remove('open'); }
        document.querySelectorAll('.modal-overlay').forEach(o => o.addEventListener('click', e => { if (e.target === o) o.classList.remove('open'); }));

        // Charts
        const pitchGreen = '#1a7a3f';
        const pitchLight = '#22a050';
        const accentYellow = '#c8f135';
        const dangerRed = '#e04040';
        const infoBlue = '#2080c0';
        const amberOrange = '#d97706';

        const gridColor = 'rgba(0,0,0,0.06)';
        const fontFamily = "'DM Sans', sans-serif";
        const defaultFont = { family: fontFamily, size: 12 };

        // Goal Chart
        new Chart(document.getElementById('goalChart'), {
          type: 'bar',
          data: {
            labels: ['H21','H22','H23','H24','H25','H26','H27','H28'],
            datasets: [{
              label: 'Toplam Gol',
              data: [18, 22, 15, 26, 20, 24, 18, 28],
              backgroundColor: pitchGreen,
              borderRadius: 6,
              borderSkipped: false,
            },{
              label: 'Ev Sahibi',
              data: [10, 13, 9, 16, 12, 15, 11, 17],
              backgroundColor: accentYellow,
              borderRadius: 6,
              borderSkipped: false,
            }]
          },
          options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { labels: { font: defaultFont, boxWidth: 12, boxHeight: 12 } } },
            scales: {
              x: { grid: { display: false }, ticks: { font: defaultFont } },
              y: { grid: { color: gridColor }, ticks: { font: defaultFont } }
            }
          }
        });

        // Result Chart (Doughnut)
        new Chart(document.getElementById('resultChart'), {
          type: 'doughnut',
          data: {
            labels: ['Galibiyet', 'Beraberlik', 'Mağlubiyet'],
            datasets: [{ data: [52, 18, 42], backgroundColor: [pitchGreen, amberOrange, dangerRed], borderWidth: 0, hoverOffset: 6 }]
          },
          options: {
            responsive: true, maintainAspectRatio: false, cutout: '65%',
            plugins: { legend: { position: 'bottom', labels: { font: defaultFont, padding: 14, boxWidth: 12 } } }
          }
        });

        // Team Goal Chart (horizontal bar)
        new Chart(document.getElementById('teamGoalChart'), {
          type: 'bar',
          data: {
            labels: ['Galatasaray','Fenerbahçe','Beşiktaş','Trabzonspor','Antalyaspor'],
            datasets: [{ label: 'Atılan Gol', data: [61,55,44,42,38], backgroundColor: [pitchGreen, '#b22222', '#5b21b6', amberOrange, '#0891b2'], borderRadius: 6, borderSkipped: false }]
          },
          options: {
            indexAxis: 'y', responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              x: { grid: { color: gridColor }, ticks: { font: defaultFont } },
              y: { grid: { display: false }, ticks: { font: defaultFont } }
            }
          }
        });

        // Win Rate Chart (stats page)
        new Chart(document.getElementById('winRateChart'), {
          type: 'radar',
          data: {
            labels: ['Galibiyet%','Savunma','Hücum','Form','Seri'],
            datasets: [
              { label: 'Galatasaray', data: [68,72,84,90,85], borderColor: pitchGreen, backgroundColor: 'rgba(26,122,63,0.1)', pointBackgroundColor: pitchGreen },
              { label: 'Fenerbahçe', data: [64,68,78,75,70], borderColor: '#b22222', backgroundColor: 'rgba(178,34,34,0.08)', pointBackgroundColor: '#b22222' }
            ]
          },
          options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { labels: { font: defaultFont, boxWidth: 12 } } },
            scales: { r: { grid: { color: gridColor }, ticks: { display: false }, pointLabels: { font: defaultFont } } }
          }
        });

        // Monthly Goal Trend
        new Chart(document.getElementById('monthlyGoalChart'), {
          type: 'line',
          data: {
            labels: ['Eyl','Eki','Kas','Ara','Oca','Şub','Mar','Nis'],
            datasets: [{
              label: 'Toplam Gol',
              data: [28,32,25,18,30,28,35,30],
              borderColor: pitchGreen, backgroundColor: 'rgba(26,122,63,0.08)',
              tension: 0.4, fill: true, pointRadius: 4, pointBackgroundColor: pitchGreen
            }]
          },
          options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              x: { grid: { display: false }, ticks: { font: defaultFont } },
              y: { grid: { color: gridColor }, ticks: { font: defaultFont } }
            }
          }
        });
    </script>
