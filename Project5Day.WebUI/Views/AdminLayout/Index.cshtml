@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
    @await Component.InvokeAsync("AdminLayoutHeadComponentPartial")
<body>

    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    @await Component.InvokeAsync("AdminLayoutSidebarComponentPartial")


    <div class="main">
        @await Component.InvokeAsync("AdminLayoutHeaderComponentPartial")

        <div class="content">
            @RenderBody()
        </div>
    </div>

    @* --- Temel JavaScript Kodların --- *@
    <script>
        // Navigation
        function showPage(pageId) {
          document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
          document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
          document.getElementById('page-' + pageId).classList.add('active');
          const labels = { dashboard:'Dashboard', teams:'Takım Yönetimi', players:'Oyuncu Yönetimi', fixtures:'Maç Yönetimi', standings:'Puan Durumu', stats:'İstatistikler' };
          document.getElementById('breadcrumb').textContent = labels[pageId] || pageId;

          if (event && event.currentTarget) {
              event.currentTarget.classList.add('active');
          }

          document.querySelectorAll('.nav-item').forEach(n => {
            if (n.getAttribute('onclick') && n.getAttribute('onclick').includes("'" + pageId + "'")) n.classList.add('active');
          });
          if (window.innerWidth < 769) closeSidebar();
        }

        // Sidebar
        function toggleSidebar() {
          document.getElementById('sidebar').classList.toggle('open');
          document.getElementById('sidebarOverlay').classList.toggle('open');
        }
        function closeSidebar() {
          document.getElementById('sidebar').classList.remove('open');
          document.getElementById('sidebarOverlay').classList.remove('open');
        }

        // Modals
        function openModal(id) { document.getElementById(id).classList.add('open'); }
        function closeModal(id) { document.getElementById(id).classList.remove('open'); }
        document.querySelectorAll('.modal-overlay').forEach(o => o.addEventListener('click', e => { if (e.target === o) o.classList.remove('open'); }));

        // Grafik Renkleri ve Ayarları (Chart.js için)
        const pitchGreen = '#1a7a3f';
        const pitchLight = '#22a050';
        const accentYellow = '#c8f135';
        const dangerRed = '#e04040';
        const gridColor = 'rgba(0,0,0,0.06)';
        const fontFamily = "'DM Sans', sans-serif";
        const defaultFont = { family: fontFamily, size: 12 };
    </script>

    @* --- KRİTİK DÜZELTME: Alt sayfalardan gelen Script bölümlerini buraya yükler --- *@
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>