@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 — Sayfa Bulunamadı | Premier Ligi</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: #0f4f28;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
        }

        /* PITCH STRIPES */
        .pitch-stripes {
            position: fixed;
            inset: 0;
            display: flex;
            z-index: 0;
        }

        .stripe {
            flex: 1;
            background: #0f4f28;
        }

            .stripe:nth-child(odd) {
                background: #1a7a3f;
            }

        /* PITCH LINES */
        .pitch-lines {
            position: fixed;
            inset: 0;
            z-index: 1;
            pointer-events: none;
        }

        /* DARK VIGNETTE */
        .vignette {
            position: fixed;
            inset: 0;
            z-index: 2;
            background: radial-gradient(ellipse at center, transparent 30%, rgba(0,0,0,0.55) 100%);
            pointer-events: none;
        }

        /* CONTENT */
        .content {
            position: relative;
            z-index: 10;
            text-align: center;
            padding: 40px 24px;
            max-width: 520px;
            width: 100%;
        }

        /* BALL */
        .ball-wrap {
            width: 120px;
            height: 120px;
            margin: 0 auto 8px;
        }

        .ball-svg {
            animation: float 2.2s ease-in-out infinite;
        }
        @@keyframes float {
            0%, 100%

        {
            transform: translateY(0) rotate(0deg);
        }

        50% {
            transform: translateY(-20px) rotate(180deg);
        }

        }

        .ball-shadow {
            width: 72px;
            height: 12px;
            background: rgba(0,0,0,0.4);
            border-radius: 50%;
            margin: 0 auto 28px;
            animation: shadowPulse 2.2s ease-in-out infinite;
        }
        @@keyframes shadowPulse {
            0%, 100%

        {
            transform: scaleX(1);
            opacity: 0.4;
        }

        50% {
            transform: scaleX(0.55);
            opacity: 0.15;
        }

        }

        /* TAG */
        .tag {
            display: inline-block;
            background: rgba(200,241,53,0.12);
            color: #c8f135;
            font-size: 11px;
            font-weight: 700;
            padding: 5px 14px;
            border-radius: 20px;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            border: 1px solid rgba(200,241,53,0.22);
            margin-bottom: 18px;
        }

        /* BIG NUMBER */
        .code {
            font-family: 'Syne', sans-serif;
            font-size: 140px;
            font-weight: 800;
            line-height: 0.85;
            color: #c8f135;
            letter-spacing: -8px;
            margin-bottom: 8px;
            text-shadow: 0 0 80px rgba(200,241,53,0.25);
        }

            .code span {
                color: rgba(200,241,53,0.2);
            }

        /* TITLE */
        .title {
            font-family: 'Syne', sans-serif;
            font-size: 26px;
            font-weight: 700;
            color: #f5f8f2;
            margin-bottom: 12px;
        }

        /* SUBTITLE */
        .sub {
            font-size: 15px;
            color: rgba(245,248,242,0.5);
            line-height: 1.7;
            margin-bottom: 36px;
            max-width: 360px;
            margin-left: auto;
            margin-right: auto;
        }

        /* BUTTONS */
        .btns {
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-primary {
            background: #c8f135;
            color: #061509;
            border: none;
            border-radius: 10px;
            padding: 13px 30px;
            font-size: 15px;
            font-weight: 700;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            transition: all 0.15s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .btn-primary:hover {
                background: #deff55;
                transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(200,241,53,0.3);
            }

        /* DIVIDER */
        .divider {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 36px auto 28px;
            max-width: 300px;
            color: rgba(245,248,242,0.18);
            font-size: 12px;
            letter-spacing: 0.06em;
            text-transform: uppercase;
        }

            .divider::before, .divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: rgba(255,255,255,0.1);
            }

        /* QUICK LINKS */
        .quick-links {
            display: flex;
            gap: 8px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .quick-link {
            background: rgba(255,255,255,0.05);
            color: rgba(245,248,242,0.5);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 8px;
            padding: 7px 14px;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.15s;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

            .quick-link:hover {
                background: rgba(255,255,255,0.1);
                color: rgba(245,248,242,0.85);
                border-color: rgba(255,255,255,0.16);
            }

            .quick-link svg {
                width: 14px;
                height: 14px;
                opacity: 0.7;
            }

        /* LOGO */
        .logo {
            position: fixed;
            top: 24px;
            left: 28px;
            z-index: 20;
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .logo-icon {
            width: 34px;
            height: 34px;
            background: #c8f135;
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .logo-text {
            font-family: 'Syne', sans-serif;
            font-size: 18px;
            font-weight: 800;
            color: #f5f8f2;
            letter-spacing: -0.3px;
        }

        /* GRASS */
        .grass {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            height: 70px;
            background: #0d3320;
            z-index: 3;
        }

        .grass-top {
            position: fixed;
            bottom: 40px;
            left: 0;
            right: 0;
            height: 32px;
            background: #1a7a3f;
            z-index: 3;
        }

        /* SCOREBOARD */
        .scoreboard {
            position: fixed;
            top: 24px;
            right: 28px;
            z-index: 20;
            background: rgba(0,0,0,0.45);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 10px;
            padding: 8px 14px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 12px;
            color: rgba(245,248,242,0.55);
            font-weight: 500;
        }

        .score-dot {
            width: 7px;
            height: 7px;
            background: #e04040;
            border-radius: 50%;
            animation: blink 1s ease-in-out infinite;
        }
        @@keyframes blink {
            0%, 100%

        {
            opacity: 1;
        }

        50% {
            opacity: 0.2;
        }

        }

        @@media (max-width: 480px) {
            .code

        {
            font-size: 100px;
            letter-spacing: -5px;
        }

        .title {
            font-size: 22px;
        }

        .logo {
            top: 16px;
            left: 16px;
        }

        .scoreboard {
            top: 16px;
            right: 16px;
        }

        .content {
            padding: 80px 20px 120px;
        }

        }
    </style>
</head>
<body>

    <div class="pitch-stripes">
