@model Project5Day.WebUI.Dtos.StadiumDtos.CreateStadiumDto

@{
    ViewData["Title"] = "Yeni Stadyum Ekle";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="page-header" style="margin-bottom: 2rem;">
    <div style="border-left: 4px solid #1a7a3f; padding-left: 12px;">
        <h3 style="color: #1a7a3f; font-weight: 800; margin: 0; text-transform: uppercase;">YENİ STADYUM KAYDI</h3>
        <p style="color: #777; font-size: 0.85rem; margin: 0;">Sisteme yeni bir stadyum tanımlayın.</p>
    </div>
</div>

<form asp-action="CreateStadium" method="post">
    <div class="row-modern">
        <div class="column-form">
            <div class="card-modern">
                <div class="input-group-modern">
                    <label><i class="fas fa-stadium"></i> Stadyum Adı</label>
                    <input type="text" asp-for="Name" id="nameInp" placeholder="Örn: Allianz Arena" required />
                </div>

                <div class="input-group-modern">
                    <label><i class="fas fa-map-marker-alt"></i> Şehir</label>
                    <input type="text" asp-for="City" id="cityInp" placeholder="Örn: Münih" required />
                </div>

                <div class="input-group-modern">
                    <label><i class="fas fa-users"></i> Kapasite</label>
                    <input type="number" asp-for="Capacity" id="capInp" placeholder="Örn: 75000" required />
                </div>

                <div class="input-group-modern">
                    <label><i class="fas fa-image"></i> Görsel URL</label>
                    <input type="text" asp-for="ImageUrl" id="imgInp" placeholder="https://..." required />
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-save"><i class="fas fa-check"></i> Kaydet</button>
                    <a href="/AdminStadium/Index" class="btn-cancel">İptal Et</a>
                </div>
            </div>
        </div>

        <div class="column-preview">
            <div class="preview-sticky">
                <div class="stadium-preview-card">
                    <div class="preview-badge">YENİ KAYIT</div>
                    <div class="preview-img-box">
                        <img id="previewImg" src="https://via.placeholder.com/400x220?text=Stadyum+Görseli" alt="">
                    </div>
                    <div class="preview-body">
                        <span id="previewCity" class="p-city">ŞEHİR</span>
                        <h4 id="previewName">Stadyum Adı</h4>
                        <div class="p-divider"></div>
                        <div class="p-cap-box">
                            <span class="p-label">KAPASİTE</span>
                            <span id="previewCap" class="p-value">0</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        const inputs = {
            name: document.getElementById('nameInp'),
            city: document.getElementById('cityInp'),
            cap: document.getElementById('capInp'),
            img: document.getElementById('imgInp')
        };

        inputs.name.addEventListener('input', e => document.getElementById('previewName').innerText = e.target.value || "Stadyum Adı");
        inputs.city.addEventListener('input', e => document.getElementById('previewCity').innerText = (e.target.value || "ŞEHİR").toUpperCase());
        inputs.cap.addEventListener('input', e => document.getElementById('previewCap').innerText = e.target.value ? new Intl.NumberFormat().format(e.target.value) : "0");
        inputs.img.addEventListener('input', e => document.getElementById('previewImg').src = e.target.value || "https://via.placeholder.com/400x220?text=Stadyum+Görseli");
    </script>
}
<style>
    .row-modern {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 2.5rem;
        align-items: start;
    }

    .card-modern {
        background: white;
        border-radius: 20px;
        padding: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        border: 1px solid #f1f4f9;
    }

    .border-update {
        border-top: 4px solid #009ef7;
    }

    .input-group-modern {
        margin-bottom: 1.2rem;
    }

        .input-group-modern label {
            display: block;
            font-weight: 700;
            color: #5e6278;
            margin-bottom: 8px;
            font-size: 0.8rem;
            text-transform: uppercase;
        }

        .input-group-modern input {
            width: 100%;
            padding: 12px 16px;
            border-radius: 12px;
            border: 2px solid #f3f6f9;
            background: #f8f9fb;
            font-weight: 600;
            transition: 0.3s;
        }

            .input-group-modern input:focus {
                border-color: #1a7a3f;
                outline: none;
                background: white;
            }

    /* Önizleme Kartı Tasarımı */
    .preview-sticky {
        position: sticky;
        top: 20px;
    }

    .stadium-preview-card {
        background: white;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        position: relative;
    }

    .preview-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        background: #1a7a3f;
        color: white;
        padding: 5px 12px;
        border-radius: 8px;
        font-size: 0.65rem;
        font-weight: 800;
        z-index: 10;
    }

    .bg-update {
        background: #009ef7;
    }

    .preview-img-box {
        height: 220px;
        background: #f3f6f9;
    }

        .preview-img-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .preview-body {
        padding: 1.5rem;
        text-align: center;
    }

    .p-city {
        color: #009ef7;
        font-weight: 800;
        font-size: 0.75rem;
        letter-spacing: 1px;
    }

    .preview-body h4 {
        margin: 5px 0 15px 0;
        font-size: 1.4rem;
        font-weight: 800;
        color: #181c32;
    }

    .p-divider {
        height: 1px;
        background: #eff2f5;
        margin-bottom: 15px;
    }

    .p-label {
        display: block;
        font-size: 0.65rem;
        color: #b5b5c3;
        font-weight: 700;
    }

    .p-value {
        font-size: 1.8rem;
        font-weight: 900;
        color: #1a7a3f;
    }

    /* Butonlar */
    .btn-save, .btn-update {
        border: none;
        padding: 14px;
        border-radius: 12px;
        font-weight: 700;
        width: 100%;
        cursor: pointer;
        transition: 0.3s;
        margin-bottom: 10px;
        color: white;
    }

    .btn-save {
        background: #1a7a3f;
    }

    .btn-update {
        background: #009ef7;
    }

    .btn-cancel {
        display: block;
        text-align: center;
        color: #b5b5c3;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.85rem;
    }

    @@media (max-width: 992px) {
        .row-modern

    {
        grid-template-columns: 1fr;
    }

    }
</style>