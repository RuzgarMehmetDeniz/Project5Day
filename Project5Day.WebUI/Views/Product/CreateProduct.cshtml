@model CreateProductDto

@{
    ViewData["Title"] = "Yeni Ürün Ekle";
    Layout = null;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">
    <h2 class="mb-4">Yeni Ürün Ekle</h2>

    <form method="post">

        <div class="mb-3">
            <label class="form-label">Ürün Adı</label>
            <input type="text" class="form-control" asp-for="ProductName" />
        </div>

        <div class="mb-3">
            <label class="form-label">Stok</label>
            <input type="number" class="form-control" asp-for="Stock" />
        </div>

        <div class="mb-3">
            <label class="form-label">Fiyat</label>
            <input type="number" step="0.01" class="form-control" asp-for="Price" />
        </div>

        <div class="mb-3">
            <label class="form-label">Kategori Id</label>
            <input type="number" class="form-control" asp-for="CategoryId" />
        </div>

        <button type="submit" class="btn btn-primary">Kaydet</button>
        <a href="/Product/ProductList" class="btn btn-secondary">Listeye Dön</a>

    </form>
</div>