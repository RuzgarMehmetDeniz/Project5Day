
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
    @await Component.InvokeAsync("MatchFixturesHeadComponentPartial")
<body>

    <!-- NAVBAR -->
    @await Component.InvokeAsync("MatchIndexNavbarComponentPartial")

    <!-- PAGE HEADER -->
    @await Component.InvokeAsync("MatchFixturesHeaderComponentPartial")

    <!-- MAIN -->
    <main>
        <div class="wrap">
            <div class="content">

                <!-- WEEK SUMMARY -->
                @await Component.InvokeAsync("MatchFixturesSummaryComponentPartial")

                <!-- ═══════════════ FRIDAY ═══════════════ -->
                @await Component.InvokeAsync("MatchFixturesFridayComponentPartial")

                <!-- ═══════════════ SATURDAY ═══════════════ -->
                @await Component.InvokeAsync("MatchFixturesSaturdayComponentPartial")

                <!-- ═══════════════ SUNDAY ═══════════════ -->
                @await Component.InvokeAsync("MatchFixturesSundayComponentPartial")

            </div>
        </div>
    </main>

    <!-- FOOTER -->
    @await Component.InvokeAsync("MatchIndexFooterComponentPartial")

    @await Component.InvokeAsync("MatchFixturesScriptComponentPartial")

</body>
</html>
