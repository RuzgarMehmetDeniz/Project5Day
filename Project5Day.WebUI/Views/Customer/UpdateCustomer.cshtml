@model Project5Day.WebUI.Dtos.CustomerDtos.UpdateCustomerDto

@{
    Layout = null;
}

<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">
    <div class="card shadow p-4">
        <h3 class="mb-4">Müşteri Güncelleme Sayfası</h3>

        <form method="post">

            <input type="hidden" asp-for="customerId" />

            <label class="form-label">Müşteri Adı:</label>
            <input type="text" asp-for="customerName" class="form-control" />
            <br />

            <label class="form-label">Müşteri Soyadı:</label>
            <input type="text" asp-for="customerSurname" class="form-control" />
            <br />

            <label class="form-label">Müşteri Şehir:</label>
            <input type="text" asp-for="customerCity" class="form-control" />
            <br />

            <button class="btn btn-primary">Müşteri Güncelle</button>
        </form>
    </div>
</div>